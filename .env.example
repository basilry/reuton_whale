# On-chain collectors
ETHERSCAN_API_KEY=
SOLSCAN_API_KEY=

# LLM router
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# Telethon listener
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_SESSION=whalescope
# Local-only. Used for the first interactive auth to generate TELETHON_SESSION_STRING.
# Do NOT set this on Render; workers cannot answer interactive prompts.
TELETHON_PHONE=
# Required for Render listener worker. Generate locally once, then paste the string here.
TELETHON_SESSION_STRING=
TG_CHANNEL=@whale_alert_io
# Seconds without a message before health_status flips to "stale".
# Unset/blank/<=0/non-numeric -> falls back to 900 (15 minutes).
LISTENER_STALENESS_SECONDS=900

# Google Sheets storage
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_JSON=

# Telegram bot
# Secret token from @BotFather. Used by pipeline (sendMessage) and bot worker.
TELEGRAM_BOT_TOKEN=
# Optional Telegram bot handle for direct DM testing. Not used by the public user-home CTA anymore.
TELEGRAM_BOT_USERNAME=

# Public Telegram channel handle for the user-home CTA and QR.
# Referenced by the Next.js dashboard via NEXT_PUBLIC_TELEGRAM_CHANNEL_USERNAME.
TELEGRAM_CHANNEL_USERNAME=whalescope_alertz

# Telegram public broadcast
# Optional public channel broadcast target. Keep disabled by default for safety.
# The bot token used here must be an admin of the target channel to post successfully.
TELEGRAM_BROADCAST_ENABLED=false
# Dry-run stays true by default so the daily pipeline logs intent without posting publicly.
TELEGRAM_BROADCAST_DRY_RUN=true
TELEGRAM_BROADCAST_CHAT=@whalescope_alertz
# Optional override. If blank, the pipeline reuses TELEGRAM_BOT_TOKEN.
TELEGRAM_BROADCAST_BOT_TOKEN=

# Streamlit dashboard (deprecated: Streamlit UI is retired, kept only for legacy scripts).
STREAMLIT_PASSWORD=

# Next.js operator dashboard auth. Consumed by apps/dashboard on Vercel; Python services ignore this.
DASHBOARD_PASSWORD=
