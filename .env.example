# ==============================================================================
# WhaleScope 환경 변수 예시 (.env.example)
# ------------------------------------------------------------------------------
# 이 파일은 Render Environment Group과 Vercel 프로젝트 설정의 단일 소스로 활용된다.
# 실제 값은 `.env`(Python 파이프라인/로컬 실행) 또는 Render/Vercel 콘솔에 입력한다.
# 주석에는 용도·기본값·배포 환경별 주의사항을 포함했다.
# ==============================================================================


# ------------------------------------------------------------------------------
# 1) 온체인 수집기 (Chain Collectors)
# ------------------------------------------------------------------------------
# Etherscan v2 API 키 — ERC-20 transfer / 고래 트랜잭션 조회용. 필수.
ETHERSCAN_API_KEY=
# Solscan Pro API 키 — SOL/SPL 고래 트랜잭션 조회용. 필수.
SOLSCAN_API_KEY=

# BTC 인덱서 (옵션) — Blockstream 등 호환 API. 미설정 시 BTC 수집은 skip.
BTC_INDEXER_BASE=
BTC_INDEXER_KEY=
# DOGE 인덱서 (옵션) — BlockCypher 등 호환 API. 미설정 시 DOGE 수집은 skip.
DOGE_INDEXER_BASE=
DOGE_INDEXER_KEY=
# Tron (TRX/USDT-TRC20) 인덱서 — TronGrid 공식 엔드포인트 기본 사용 가능.
TRONGRID_API_BASE=https://api.trongrid.io
TRONGRID_API_KEY=

# XRP 수집 토글 (Phase 2a). 안정화 전에는 false로 유지.
ENABLE_CHAIN_XRP=false
# XRPSCAN 호환 API base (옵션 override).
XRPSCAN_API_BASE=https://api.xrpscan.com/api/v1


# ------------------------------------------------------------------------------
# 2) LLM 라우터 (Analyzer / Brief)
# ------------------------------------------------------------------------------
# Anthropic API 키 — Sonnet/Opus 사용. daily_brief full/incremental 프롬프트의 기본 호출처.
ANTHROPIC_API_KEY=
# Gemini API 키 — fallback/저비용 라우팅 용도.
GEMINI_API_KEY=
# Groq API 키 — Llama-3.x 계열 저지연 fallback.
GROQ_API_KEY=

# daily_brief full 모드에서 전달할 RSS 상위 N건. 기본 20.
RSS_NEWS_TOP_N=20


# ------------------------------------------------------------------------------
# 3) Telethon Listener (Telegram 고래 채널 수신)
# ------------------------------------------------------------------------------
# my.telegram.org 에서 발급. 필수.
TELETHON_API_ID=
TELETHON_API_HASH=

# 세션 파일 이름. 로컬에서만 사용.
TELETHON_SESSION=whalescope
# 로컬 최초 인증 전용 — Render/서버 워커에는 절대 넣지 말 것(대화형 프롬프트 응답 불가).
TELETHON_PHONE=
# Render listener 워커의 인증용 세션 문자열. 로컬에서 한 번 생성 후 붙여넣기.
TELETHON_SESSION_STRING=

# 수집 대상 Telegram 채널 핸들 (프로덕션에서는 공식 whale_alert_io 추천).
TG_CHANNEL=@whale_alert_io

# N초 동안 신규 메시지가 없으면 health_status가 "stale"로 전환. 공란/0/음수 -> 900(15분).
LISTENER_STALENESS_SECONDS=900


# ------------------------------------------------------------------------------
# 4) Google Sheets 저장소
# ------------------------------------------------------------------------------
# 시트 ID (URL의 /d/ 뒤 토큰). 필수.
GOOGLE_SHEET_ID=
# 서비스 계정 JSON 전체 문자열. Render에서는 따옴표로 감싼 한 줄 JSON으로 입력.
GOOGLE_CREDENTIALS_JSON=


# ------------------------------------------------------------------------------
# 5) Telegram Bot (알림 / 브리핑 전송)
# ------------------------------------------------------------------------------
# @BotFather 토큰. 파이프라인(sendMessage)·봇 워커·방송에 공용으로 사용.
TELEGRAM_BOT_TOKEN=
# 직접 DM 테스트용 봇 핸들(옵션). 공개 CTA에는 사용하지 않음.
TELEGRAM_BOT_USERNAME=

# 공개 채널 핸들 — 대시보드 CTA/QR이 참조.
# Next.js 쪽에서는 NEXT_PUBLIC_TELEGRAM_CHANNEL_USERNAME 로도 노출.
TELEGRAM_CHANNEL_USERNAME=whalescope_alertz

# 방송 기능 — 공개 채널에 자동 게시. 기본 OFF(안전).
TELEGRAM_BROADCAST_ENABLED=false
# Dry-run은 기본 true — 파이프라인이 의도만 로깅, 실제 게시 금지.
TELEGRAM_BROADCAST_DRY_RUN=true
# 방송 대상 chat id 또는 @handle.
TELEGRAM_BROADCAST_CHAT=@whalescope_alertz
# 별도 방송 전용 봇 토큰. 비워두면 TELEGRAM_BOT_TOKEN 재사용.
TELEGRAM_BROADCAST_BOT_TOKEN=


# ------------------------------------------------------------------------------
# 6) Next.js 대시보드 공개 변수 (Vercel 전용, NEXT_PUBLIC_*)
# ------------------------------------------------------------------------------
# 클라이언트 번들에 노출되어 CTA 버튼·QR 생성에 쓰인다.
NEXT_PUBLIC_TELEGRAM_CHANNEL_USERNAME=whalescope_alertz
NEXT_PUBLIC_TELEGRAM_BROADCAST_CHANNEL=whalescope_alertz


# ------------------------------------------------------------------------------
# 7) 대시보드 인증 / 운영 플래그
# ------------------------------------------------------------------------------
# Next.js 운영 대시보드(/admin 등) Basic-Auth 비밀번호. Python 서비스는 무시.
DASHBOARD_PASSWORD=
# (deprecated) Streamlit UI 잔존 스크립트용. 신규 사용 금지.
STREAMLIT_PASSWORD=

# true -> 게스트에게도 /admin 프리뷰 허용(데모/스크린샷용). 실 운영은 공란/false.
WHALESCOPE_PUBLIC_ADMIN_PREVIEW=false
# true -> 큐레이션 워치리스트 seed를 건너뜀(테스트/재현용).
WHALESCOPE_CURATED_DISABLE_SEED=false


# ------------------------------------------------------------------------------
# 8) Upstash Redis REST — 실시간 SSE 스트림 백엔드
# ------------------------------------------------------------------------------
# 미설정 시 대시보드 상단 상태 배지가 "실시간 비활성(standby)"으로 표시된다.
# Upstash 콘솔에서 REST URL과 토큰을 발급해 Vercel/Render에 모두 주입.
WHALESCOPE_REDIS_REST_URL=
WHALESCOPE_REDIS_REST_TOKEN=


# ------------------------------------------------------------------------------
# 9) Render Admin Observability (/admin 대시보드 Render 섹션)
# ------------------------------------------------------------------------------
# Render API 키 — 계정 설정 > API Keys에서 발급. read-only 스코프로 충분.
RENDER_API_KEY=
# Render 오너 ID (팀/개인 계정 ID). `https://api.render.com/v1/owners` 응답 id.
RENDER_OWNER_ID=
# 감시 대상 서비스 3종의 Render 서비스 ID (srv_xxx 형태).
RENDER_SERVICE_ID_PIPELINE=
RENDER_SERVICE_ID_LISTENER=
RENDER_SERVICE_ID_BOT=


# ------------------------------------------------------------------------------
# 10) 수동 운영 오버라이드
# ------------------------------------------------------------------------------
# true로 설정 시 일일 브리핑 방송이 슬롯 상관없이 즉시 트리거. CI/긴급 재방송용.
FORCE_BROADCAST_DAILY=false
