# Server-only secrets. Keep these out of the browser bundle and Vercel public env.
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_JSON=
DASHBOARD_PASSWORD=
RENDER_PIPELINE_WEBHOOK_URL=
RENDER_PIPELINE_WEBHOOK_SECRET=

# Public values that are safe to expose through NEXT_PUBLIC_.
NEXT_PUBLIC_APP_NAME=WhaleScope
# Public bot handle without the leading "@". Current WhaleScope demo bot: whalescope_demo_bot
# -> https://t.me/whalescope_demo_bot
# Used by the user home Telegram QR modal to build tg://resolve?domain=... and https://t.me/... links.
# Keep this value identical to TELEGRAM_BOT_USERNAME in the root .env.example.
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=whalescope_demo_bot
