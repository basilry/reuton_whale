# Server-only secrets. Keep these out of the browser bundle and Vercel public env.
GOOGLE_SHEET_ID=
GOOGLE_CREDENTIALS_JSON=
DASHBOARD_PASSWORD=
RENDER_PIPELINE_WEBHOOK_URL=
RENDER_PIPELINE_WEBHOOK_SECRET=

# Public values that are safe to expose through NEXT_PUBLIC_.
NEXT_PUBLIC_APP_NAME=WhaleScope
# Public Telegram channel handle without the leading "@". Current public channel: whalescope_alertz
# -> https://t.me/whalescope_alertz
# Used by the user home Telegram QR modal to build the public channel link and QR image.
NEXT_PUBLIC_TELEGRAM_CHANNEL_USERNAME=whalescope_alertz
