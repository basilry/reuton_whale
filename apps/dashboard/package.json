  },
  "dependencies": {
    "@types/node": "^20.19.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "google-auth-library": "^9.15.1",
    "lightweight-charts": "^5.1.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@playwright/experimental-ct-react": "^1.56.1",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.5.0",
    "playwright": "^1.56.1"
  }
}
