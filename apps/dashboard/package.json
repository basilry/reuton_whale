{
  "name": "whalescope-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --stack-size=8000 ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
